[Unit]
Description=node Prometheus exporter

[Container]
Image=quay.io/prometheus/node-exporter:latest
User=65534
Group=65534
Network=host
NoNewPrivileges=yes
ReadOnly=yes
Volume=/:/host:ro,rslave
PodmanArgs=--pid=host
PodmanArgs=--cpus=1
PodmanArgs=--memory=128m
Exec=--path.rootfs=/host --collector.ntp --collector.textfile.directory=/host/srv/node-exporter --path.udev.data=/host/run/udev/data
AutoUpdate=registry

[Service]
Restart=always

[Install]
WantedBy=multi-user.target
