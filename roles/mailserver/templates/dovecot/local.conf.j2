protocols = imap lmtp sieve

mail_debug = no  # for sieve debugging

mail_home = /srv/mail/domains/%d/users/%n
mail_location = maildir:~/Maildir
mail_uid = mailstore
mail_gid = mailstore
first_valid_uid = {{ _mailserver_dovecot_mailstore_user.uid }}
last_valid_uid = {{ _mailserver_dovecot_mailstore_user.uid }}
first_valid_gid = {{ _mailserver_dovecot_mailstore_user.group }}
last_valid_gid = {{ _mailserver_dovecot_mailstore_user.group }}

ssl = required
#ssl_key = <...
#ssl_cert = <...

mail_plugins = $mail_plugins quota

quota_full_tempfail = yes

#auth_krb5_keytab =
auth_mechanisms = plain gssapi

passdb {
  driver = ldap
  args = /etc/dovecot/dovecot-ldap.conf.ext
}

userdb {
  driver = ldap
  args = /etc/dovecot/dovecot-ldap.conf.ext
}

plugin {
  quota = maildir:User quota
  quota_rule = *:storage=100MB
  #quota_rule2 = Trash:storage+=100M
  #quota_rule3 = Spam:storage+=50M
}

protocol imap {
  mail_plugins = $mail_plugins imap_quota imap_sieve
  imap_metadata = yes
}

protocol lmtp {
  mail_plugins = $mail_plugins sieve
}

lmtp_save_to_detail_mailbox = yes

plugin {
  recipient_delimiter = +-

  sieve_global_extensions = +vnd.dovecot.pipe +vnd.dovecot.debug
  sieve_plugins = sieve_extprograms sieve_imapsieve

  sieve_before = file:/etc/dovecot/sieve/spam.sieve

  imapsieve_url = sieve://imap.robots.org.uk

  imapsieve_mailbox1_name = *
  imapsieve_mailbox1_causes = COPY
  imapsieve_mailbox1_before = file:/etc/dovecot/sieve/on-move.sieve

  sieve_pipe_bin_dir = /usr/local/libexec/dovecot/sieve

  sieve_quota_max_scripts = 10
  sieve_quota_max_storage = 1M
}

lmtp_save_to_detail_mailbox = yes
#lmtp_rcpt_check_quota = yes

service auth {
  unix_listener postfix {
    mode = 0660
    group = postfix
  }
}

service lmtp {
  unix_listener lmtp {
    mode = 0660
    group = postfix
  }
}

postmaster_address = postmaster@robots.org.uk

mail_max_userip_connections = 10

# Some alternatives to the mailboxes already defined
# 15-mailboxes.conf
#
namespace inbox {
  mailbox "Spam" {
    auto = subscribe
    special_use = \Junk
    #autoexpunge = ?
    #mailbox_list_index = yes  ... global setting?
    #mailbox_always_cache_fields = date.save
  }

  mailbox "Deleted Items" {
    special_use = \Trash
  }

  mailbox "Sent Items" {
    special_use = \Sent
  }
}

mail_attribute_dict = file:%h/Maildir/dovecot-attributes

